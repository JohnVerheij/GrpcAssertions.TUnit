<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>GrpcAssertions.Tests</RootNamespace>
    <AssemblyName>GrpcAssertions.Tests</AssemblyName>

    <IsPackable>false</IsPackable>
    <IsPublishable>false</IsPublishable>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <!--
      This project tests the framework-agnostic core (GrpcAssertions) in isolation.
      It deliberately does NOT reference GrpcAssertions.TUnit (the adapter); if a future
      regression leaks a TUnit type into the core's public surface, the compile breaks here
      before the adapter project hides it via its own TUnit reference. The runner-side TUnit
      package below is an orthogonal choice (consistent with family convention); it does not
      re-introduce GrpcAssertions.TUnit.
    -->
    <PackageReference Include="TUnit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/GrpcAssertions/GrpcAssertions.csproj" />
  </ItemGroup>

</Project>
